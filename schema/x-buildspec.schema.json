{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shivanandiyer/project-specforge/schema/x-buildspec.schema.json",
  "title": "specforge x-buildspec extension block",
  "description": "JSON Schema for the x-buildspec ODCS extension (docs/spec/dsl-specification.md).",
  "type": "object",
  "additionalProperties": false,
  "required": ["build", "sources", "transformation", "operations"],
  "properties": {
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "agent"],
      "properties": {
        "target": { "enum": ["auto", "lakeflow", "dbt"] },
        "hint": { "enum": ["batch", "streaming", "dimensional"] },
        "agent": { "enum": ["claude_code", "genie_code"] },
        "iteration_budget": { "type": "integer", "minimum": 1 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "connection"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "connection": {
            "type": "string",
            "pattern": "^uc:",
            "description": "UC reference only — never inline credentials (DSL §1)."
          },
          "expectation": { "enum": ["cdc", "snapshot", "append"] }
        }
      }
    },
    "transformation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent"],
      "properties": {
        "derivations": {
          "type": "object",
          "description": "Single-row calculated-column expressions (ADR-0007). No agent involved.",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "intent": {
          "type": "string",
          "minLength": 1,
          "description": "Guidance for the builder agent, never enforced truth (DSL §4)."
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environments"],
      "properties": {
        "environments": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["catalog", "schema"],
            "properties": {
              "catalog": { "type": "string", "minLength": 1 },
              "schema": { "type": "string", "minLength": 1 }
            }
          }
        },
        "compute": { "enum": ["serverless", "job_cluster"] },
        "schedule": {
          "type": "string",
          "description": "Cron expression."
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "publish_spec": { "type": "boolean" },
        "grants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["principal", "privilege"],
            "properties": {
              "principal": { "type": "string", "minLength": 1 },
              "privilege": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
